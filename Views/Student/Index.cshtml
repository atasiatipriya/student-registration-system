@model List<StudentRegistrationSystem.Models.Student>

@{
    ViewData["Title"] = "Student Registration System";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Student Registration System</title>
    <style>
            * { margin: 0; padding: 0; box-sizing: border-box; }

            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background-color: #f0f4f8;
                color: #333;
            }

            header {
                background: linear-gradient(135deg, #4f46e5, #7c3aed);
                color: white;
                padding: 32px 20px;
                text-align: center;
            }

            header h1 { font-size: 2rem; margin-bottom: 8px; }
            header p  { font-size: 1rem; opacity: 0.85; }

            main {
                max-width: 960px;
                margin: 32px auto;
                padding: 0 20px;
            }

            /* SUCCESS BANNER */
            .success-banner {
                background: #d1fae5;
                color: #065f46;
                border: 1.5px solid #6ee7b7;
                border-radius: 8px;
                padding: 14px 20px;
                font-weight: 600;
                margin-bottom: 24px;
                text-align: center;
            }

            /* FORM */
            .form-section {
                background: white;
                border-radius: 12px;
                padding: 32px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.07);
                margin-bottom: 32px;
            }

            .form-section h2 {
                font-size: 1.3rem;
                color: #4f46e5;
                margin-bottom: 24px;
                padding-bottom: 10px;
                border-bottom: 2px solid #ede9fe;
            }

            .form-group {
                margin-bottom: 18px;
                display: flex;
                flex-direction: column;
            }

            .form-group label {
                font-size: 0.9rem;
                font-weight: 600;
                color: #444;
                margin-bottom: 6px;
            }

            .form-group input,
            .form-group select {
                padding: 10px 14px;
                border: 1.5px solid #d1d5db;
                border-radius: 8px;
                font-size: 0.95rem;
                outline: none;
                transition: border-color 0.2s;
            }

            .form-group input:focus,
            .form-group select:focus {
                border-color: #4f46e5;
            }

            .required { color: #ef4444; }

            .btn-submit {
                background: #4f46e5;
                color: white;
                padding: 11px 28px;
                border: none;
                border-radius: 8px;
                font-size: 0.95rem;
                font-weight: 600;
                cursor: pointer;
            }

            .btn-submit:hover { background: #4338ca; }

            /* TABLE */
            .table-section {
                background: white;
                border-radius: 12px;
                padding: 32px;
                box-shadow: 0 2px 12px rgba(0,0,0,0.07);
            }

            .table-section h2 {
                font-size: 1.3rem;
                color: #4f46e5;
                margin-bottom: 20px;
                padding-bottom: 10px;
                border-bottom: 2px solid #ede9fe;
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .count-badge {
                background: #4f46e5;
                color: white;
                font-size: 0.8rem;
                padding: 2px 10px;
                border-radius: 99px;
            }

            .table-wrapper { overflow-x: auto; }

            table {
                width: 100%;
                border-collapse: collapse;
                font-size: 0.9rem;
            }

            thead tr { background: #ede9fe; }

            thead th {
                padding: 12px 14px;
                text-align: left;
                font-weight: 600;
                color: #4f46e5;
                white-space: nowrap;
            }

            tbody tr { border-bottom: 1px solid #f3f4f6; }
            tbody tr:hover { background: #faf9ff; }

            tbody td {
                padding: 12px 14px;
                color: #444;
                white-space: nowrap;
            }

            .btn-delete {
                background: #fee2e2;
                color: #b91c1c;
                border: none;
                padding: 6px 14px;
                border-radius: 6px;
                font-size: 0.82rem;
                font-weight: 600;
                cursor: pointer;
                text-decoration: none;
            }

            .btn-delete:hover { background: #fecaca; }

            .empty-msg {
                text-align: center;
                color: #aaa;
                padding: 32px 0;
            }

            footer {
                background: #1e1b4b;
                color: #a5b4fc;
                text-align: center;
                padding: 18px;
                font-size: 0.85rem;
                margin-top: 40px;
            }
    </style>
</head>
<body>

    <header>
        <h1>Student Registration System</h1>
        <p>Built with HTML5, CSS3, JavaScript, C# ASP.NET Core &amp; SQL Server</p>
    </header>

    <main>

        @* SUCCESS MESSAGE *@
        @if (TempData["Success"] != null)
        {
            <div class="success-banner">
                @TempData["Success"]
            </div>
        }

        @* REGISTRATION FORM *@
        <section class="form-section">
            <h2>Register a Student</h2>

            <form method="post" action="/Student/Register">
                <div class="form-group">
                    <label>Full Name <span class="required">*</span></label>
                    <input type="text" name="FullName" placeholder="e.g. Atasi Atipriya Rout" required />
                </div>

                <div class="form-group">
                    <label>Email Address <span class="required">*</span></label>
                    <input type="email" name="Email" placeholder="e.g. atasi@gmail.com" required />
                </div>

                <div class="form-group">
                    <label>Phone Number <span class="required">*</span></label>
                    <input type="text" name="Phone" placeholder="e.g. 9876543210" required />
                </div>

                <div class="form-group">
                    <label>Course <span class="required">*</span></label>
                    <select name="Course" required>
                        <option value="">-- Select a Course --</option>
                        <option value="B.Tech CSE">B.Tech CSE</option>
                        <option value="B.Tech ECE">B.Tech ECE</option>
                        <option value="BCA">BCA</option>
                        <option value="MCA">MCA</option>
                        <option value="MBA">MBA</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Year of Study <span class="required">*</span></label>
                    <select name="YearOfStudy" required>
                        <option value="">-- Select Year --</option>
                        <option value="1st Year">1st Year</option>
                        <option value="2nd Year">2nd Year</option>
                        <option value="3rd Year">3rd Year</option>
                        <option value="4th Year">4th Year</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Date of Birth <span class="required">*</span></label>
                    <input type="date" name="DateOfBirth" required />
                </div>

                <button type="submit" class="btn-submit">Register Student</button>
            </form>
        </section>

        @* STUDENTS TABLE *@
        <section class="table-section">
            <h2>
                Registered Students
                <span class="count-badge">@Model.Count</span>
            </h2>

            <div class="table-wrapper">
                @if (Model.Count == 0)
                {
                    <p class="empty-msg">No students registered yet.</p>
                }
                else
                {
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Course</th>
                                <th>Year</th>
                                <th>Date of Birth</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td>@Model[i].FullName</td>
                                    <td>@Model[i].Email</td>
                                    <td>@Model[i].Phone</td>
                                    <td>@Model[i].Course</td>
                                    <td>@Model[i].YearOfStudy</td>
                                    <td>@Model[i].DateOfBirth.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <a href="/Student/Delete/@Model[i].StudentID"
                                           class="btn-delete"
                                           onclick="return confirm('Delete this student?')">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </section>

    </main>

    <footer>
        <p>Student Registration System &copy; 2026 | Atasi Atipriya Rout</p>
    </footer>

</body>
</html>
